{
	"baseDefines": [],
	"checks": [{
		"props": {},
		"type": "Anonymous"
	}, {
		"props": {
			"spaceBefore": false,
			"spaceInside": false
		},
		"type": "ArrayAccess"
	}, {
		"props": {},
		"type": "ArrayLiteral"
	}, {
		"props": {
			"allowSingleArgParens": true,
			"allowCurlyBody": true,
			"allowFunction": true,
			"allowReturn": true
		},
		"type": "ArrowFunction"
	}, {
		"props": {
			"avoidIdentifiers": []
		},
		"type": "AvoidIdentifier"
	}, {
		"props": {},
		"type": "AvoidStarImport"
	}, {
		"props": {
			"severity": "IGNORE"
		},
		"type": "AvoidTernaryOperator"
	}, {
		"props": {},
		"type": "BlockBreakingConditional"
	}, {
		"props": {
			"format": "^(e|t|ex|[a-z][a-z][a-zA-Z]+)$"
		},
		"type": "CatchParameterName"
	}, {
		"props": {
			"severityIdentical": "WARNING",
			"thresholdIdentical": 60,
			"thresholdSimilar": 120
		},
		"type": "CodeSimilarity"
	}, {
		"props": {
			"allowSingleline": true,
			"policy": "aligned",
			"severity": "INFO"
		},
		"type": "ConditionalCompilation"
	}, {
		"props": {
			"severity": "IGNORE",
			"thresholds": [{
				"complexity": 20,
				"severity": "WARNING"
			}, {
				"complexity": 25,
				"severity": "ERROR"
			}]
		},
		"type": "CyclomaticComplexity"
	}, {
		"props": {},
		"type": "DefaultComesLast"
	}, {
		"props": {
			"lineStyle": "onestar",
			"startStyle": "twostars",
			"severity": "IGNORE"
		},
		"type": "DocCommentStyle"
	}, {
		"props": {
			"severity": "IGNORE"
		},
		"type": "Dynamic"
	}, {
		"props": {
			"option": "empty",
			"tokens": [
				"ABSTRACT_DEF",
				"CATCH",
				"CLASS_DEF",
				"ENUM_DEF",
				"FOR",
				"FUNCTION",
				"IF",
				"INTERFACE_DEF",
				"OBJECT_DECL",
				"SWITCH",
				"TRY",
				"TYPEDEF_DEF",
				"WHILE"
			]
		},
		"type": "EmptyBlock"
	}, {
		"props": {
			"allowEmptyLineAfterMultiLineComment": true,
			"allowEmptyLineAfterSingleLineComment": true,
			"requireEmptyLineAfterAbstract": true,
			"requireEmptyLineAfterClass": true,
			"requireEmptyLineAfterInterface": true,
			"requireEmptyLineAfterPackage": true,
			"max": 1
		},
		"type": "EmptyLines"
	}, {
		"props": {
			"enforceEmptyPackage": true
		},
		"type": "EmptyPackage"
	}, {
		"props": {},
		"type": "ERegLiteral"
	}, {
		"props": {
			"atleast": [],
			"defaultPolicy": "upto",
			"exact": [],
			"ignore": [],
			"max": 1,
			"none": [],
			"skipSingleLineTypes": true,
			"upto": []
		},
		"type": "ExtendedEmptyLines"
	}, {
		"props": {
			"ignoreEmptyLines": true,
			"max": 1000,
			"severity": "IGNORE"
		},
		"type": "FileLength"
	}, {
		"type": "Anonymous"
	}, {
		"props": {
			"option": "upperCase"
		},
		"type": "HexadecimalLiteral"
	}, {
		"props": {
			"ignoreConstructorParameter": true,
			"ignoreFormat": "^(main|run)$",
			"ignoreSetter": true
		},
		"type": "HiddenField"
	}, {
		"props": {
			"character": "tab",
			"severity": "IGNORE"
		},
		"type": "Indentation"
	}, {
		"props": {
			"character": "tab",
			"severity": "INFO",
			"ignorePattern": "^$"
		},
		"type": "IndentationCharacter"
	}, {
		"props": {
			"ignoreReturnAssignments": true,
			"severity": "WARNING"
		},
		"type": "InnerAssignment"
	}, {
		"props": {
			"allowProperties": true,
			"allowMarkerInterfaces": true
		},
		"type": "Interface"
	}, {
		"props": {
			"severity": "IGNORE"
		},
		"type": "LeftCurly"
	}, {
		"props": {
			"max": 160,
			"ignorePattern": "^$"
		},
		"type": "LineLength"
	}, {
		"props": {
			"format": "^_?[a-z][a-zA-Z0-9]*$"
		},
		"type": "ListenerName"
	}, {
		"props": {
			"format": "^[a-z][a-zA-Z0-9]*$"
		},
		"type": "LocalVariableName"
	}, {
		"props": {
			"ignoreNumbers": [-1, 0, 1, 2],
			"severity": "IGNORE"
		},
		"type": "MagicNumber"
	}, {
		"props": {
			"format": "^[a-z][a-zA-Z0-9]*$",
			"tokens": ["ABSTRACT"]
		},
		"type": "MemberName"
	}, {
		"props": {
			"format": "^[_a-z][a-z][a-zA-Z0-9]*$",
			"tokens": ["ABSTRACT"]
		},
		"type": "MemberName"
	}, {
		"props": {
			"format": "^[_a-z][a-zA-Z0-9]*$",
			"tokens": ["CLASS", "PRIVATE", "PUBLIC", "TYPEDEF"]
		},
		"type": "MemberName"
	}, {
		"props": {
			"maxPrivate": 100,
			"maxPublic": 100,
			"maxTotal": 100
		},
		"type": "MethodCount"
	}, {
		"props": {
			"ignoreEmptyLines": true,
			"max": 50,
			"severity": "IGNORE"
		},
		"type": "MethodLength"
	}, {
		"props": {
			"format": "^[a-z][a-zA-Z0-9]*$",
			"ignoreExtern": true,
			"tokens": [],
			"severity": "IGNORE"
		},
		"type": "MethodName"
	}, {
		"props": {
			"modifiers": [
				"PUBLIC_PRIVATE",
				"STATIC",
				"FINAL",
				"ABSTRACT",
				"INLINE",
				"MACRO",
				"DYNAMIC",
				"EXTERN"
			]
		},
		"type": "ModifierOrder"
	}, {
		"props": {
			"allowDuplicates": 5,
			"ignore": "^\\s+$",
			"minLength": 2
		},
		"type": "MultipleStringLiterals"
	}, {
		"props": {},
		"type": "MultipleVariableDeclarations"
	}, {
		"props": {
			"max": 3,
			"severity": "IGNORE"
		},
		"type": "NestedControlFlow"
	}, {
		"props": {
			"max": 1,
			"severity": "IGNORE"
		},
		"type": "NestedForDepth"
	}, {
		"props": {
			"max": 4
		},
		"type": "NestedIfDepth"
	}, {
		"props": {
			"max": 1
		},
		"type": "NestedTryDepth"
	}, {
		"props": {
			"option": "questionMark"
		},
		"type": "NullableParameter"
	}, {
		"props": {
			"arrowPolicy": "around",
			"arrowFunctionPolicy": "around",
			"assignOpPolicy": "around",
			"arithmeticOpPolicy": "around",
			"bitwiseOpPolicy": "around",
			"boolOpPolicy": "around",
			"compareOpPolicy": "around",
			"intervalOpPolicy": "none",
			"newFunctionTypePolicy": "around",
			"oldFunctionTypePolicy": "none",
			"ternaryOpPolicy": "around",
			"unaryOpPolicy": "none"
		},
		"type": "OperatorWhitespace"
	}, {
		"props": {
			"option": "nl",
			"tokens": [
				"+",
				"-",
				"*",
				"/",
				"%",
				">",
				"<",
				">=",
				"<=",
				"==",
				"!=",
				"&",
				"|",
				"^",
				"&&",
				"||",
				"<<",
				">>",
				">>>",
				"+=",
				"-=",
				"*=",
				"/=",
				"%=",
				"<<=",
				">>=",
				">>>=",
				"|=",
				"&=",
				"^=",
				"...",
				"=>",
				"++",
				"--"
			]
		},
		"type": "OperatorWrap"
	}, {
		"props": {
			"tokens": ["="]
		},
		"type": "OperatorWrap"
	}, {
		"props": {
			"format": "^(_|[a-z][a-zA-Z0-9]*$)",
			"ignoreExtern": true,
			"tokens": []
		},
		"type": "ParameterName"
	}, {
		"props": {
			"ignoreOverriddenMethods": false,
			"max": 7
		},
		"type": "ParameterNumber"
	}, {
		"props": {
			"severity": "WARNING"
		},
		"type": "PublicAccessor"
	}, {
		"props": {
			"prohibitMeta": false
		},
		"type": "RedundantAccessMeta"
	}, {
		"props": {
			"prohibitMeta": false
		},
		"type": "RedundantAllowMeta"
	}, {
		"props": {
			"enforcePrivate": false,
			"enforcePublic": true,
			"enforcePublicPrivate": false
		},
		"type": "RedundantModifier"
	}, {
		"props": {
			"allowEmptyReturn": true,
			"enforceReturnType": true,
			"enforceReturnTypeForAnonymous": true
		},
		"type": "Return"
	}, {
		"props": {
			"ignoreFormat": "^$",
			"max": 2,
			"severity": "IGNORE"
		},
		"type": "ReturnCount"
	}, {
		"props": {
			"severity": "IGNORE"
		},
		"type": "RightCurly"
	}, {
		"props": {
			"allowTrailingComma": false,
			"semicolonPolicy": "after",
			"commaPolicy": "after",
			"dotPolicy": "none"
		},
		"type": "SeparatorWhitespace"
	}, {
		"props": {
			"tokens": [","],
			"option": "eol"
		},
		"type": "SeparatorWrap"
	}, {
		"props": {},
		"type": "SimplifyBooleanExpression"
	}, {
		"props": {},
		"type": "SimplifyBooleanReturn"
	}, {
		"props": {
			"allowException": true,
			"policy": "doubleAndInterpolation",
			"severity": "IGNORE"
		},
		"type": "StringLiteral"
	}, {
		"props": {
			"ignorePattern": "^$"
		},
		"type": "TabForAligning"
	}, {
		"props": {
			"format": "^\\s*(TODO|FIXME|HACK|XXX|BUG)"
		},
		"type": "TODOComment"
	}, {
		"props": {
			"severity": "IGNORE"
		},
		"type": "Trace"
	}, {
		"props": {},
		"type": "TrailingWhitespace"
	}, {
		"props": {
			"ignoreExtern": true,
			"format": "^[A-Z][a-zA-Z0-9]*$"
		},
		"type": "TypeName"
	}, {
		"props": {},
		"type": "UnnecessaryConstructor"
	}, {
		"props": {
			"ignoreModules": [],
			"moduleTypeMap": {}
		},
		"type": "UnusedImport"
	}, {
		"props": {},
		"type": "UnusedLocalVar"
	}, {
		"props": {
			"ignoreEnumAbstractValues": true,
			"typeHintPolicy": "enforce_all"
		},
		"type": "VarTypeHint"
	}, {
		"props": {
			"tokens": [",", ";"]
		},
		"type": "WhitespaceAfter"
	}, {
		"props": {
			"tokens": [
				"=",
				"+",
				"-",
				"*",
				"/",
				"%",
				">",
				"<",
				">=",
				"<=",
				"==",
				"!=",
				"&",
				"|",
				"^",
				"&&",
				"||",
				"<<",
				">>",
				">>>",
				"+=",
				"-=",
				"*=",
				"/=",
				"%=",
				"<<=",
				">>=",
				">>>=",
				"|=",
				"&=",
				"^=",
				"=>"
			]
		},
		"type": "WhitespaceAround"
	}],
	"defaultSeverity": "INFO",
	"defineCombinations": [],
	"exclude": {},
	"numberOfCheckerThreads": 6,
	"extendsConfigPath": "",
	"version": 1
}
