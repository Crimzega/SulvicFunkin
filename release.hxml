--define BUILD_DIR=export/release/64bit
--define BUILD_DIR=export/release/32bit

--class-path source
--class-path mod_source

--class-path .haxelib/discord_rpc/git
--class-path .haxelib/flixel/git
--class-path .haxelib/flixel-addons/git
--class-path .haxelib/flixel-text-input/1,1,0
--class-path .haxelib/flixel-ui/git
--class-path .haxelib/flxanimate/git
--class-path .haxelib/format/3,5,0
--class-path .haxelib/funkin,vis/git
--class-path .haxelib/hamcrest/3,0,0
--class-path .haxelib/haxeui-core/git
--class-path .haxelib/haxeui-flixel/git
--class-path .haxelib/hscript/2.5.0
--class-path .haxelib/hxCodec/git
--class-path .haxelib/hxcpp/4.3.2
--class-path .haxelib/hxcpp-debug-server/git
--class-path .haxelib/hxp/1.2.2
--class-path .haxelib/json2object/git
--class-path .haxelib/lime/git
