--remap flash:openfl

--define message.reporting=pretty

--define POLYMOD_DEBUG=false
--define POLYMOD_SCRIPT_EXT=.hscript
--define POLYMOD_SCRIPT_LIBRARY=scripts
--define POLYMOD_ROOT_PATH=scripts/
--define POLYMOD_APPEND_FOLDER=_append
--define POLYMOD_MERGE_FOLDER=_merge
--define POLYMOD_MOD_METADATA_FILE=_polymod_meta.json
--define POLYMOD_MOD_ICON_FILE=_polymod_icon.png

--macro include("com.sulvic.funkin")
--macro com.sulvic.funkin.macros.FunkinMacros.registerMetadatas()
